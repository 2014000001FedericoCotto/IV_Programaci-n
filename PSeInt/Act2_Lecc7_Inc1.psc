Algoritmo Act2_Lecc7_Inc1
	Definir nume,telefono Como Real
	Escribir "Opciones: "
	Escribir "1, 2, 3, 4"
	Escribir "Digite un Num."
	Leer nume
	Si nume = 1
		Escribir "Eligio la primera opción"
	FinSi
	Si nume = 2
		Escribir "Eligio la segunda opción"
	FinSi
	Si nume = 3
		Escribir "Eligio la tercera opción"
	FinSi
	Si nume = 4
		Escribir "Eligio la Cuarte opción"
		
		
	FinSi
	
	
	
FinAlgoritmo
